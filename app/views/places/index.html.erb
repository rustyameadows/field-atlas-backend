<% content_for :title, "Field Atlas Places" %>

<main class="app-shell">
  <header class="app-header">
    <div>
      <p class="eyebrow">Field Atlas Backend</p>
      <h1>Places Pipeline</h1>
      <p class="lede">Canonical places, provider source records, and the same search contract the iOS app consumes.</p>
    </div>
    <nav class="app-actions" aria-label="Verification links">
      <%= link_to "API JSON", @api_url, class: "button" %>
      <%= link_to "Health", rails_health_check_path, class: "button secondary" %>
    </nav>
  </header>

  <section class="metrics" aria-label="Database summary">
    <article>
      <span class="metric-value"><%= number_with_delimiter(@place_count) %></span>
      <span class="metric-label">Canonical places</span>
    </article>
    <article>
      <span class="metric-value"><%= number_with_delimiter(@source_record_count) %></span>
      <span class="metric-label">Source records</span>
    </article>
    <article>
      <span class="metric-value"><%= @search_response.fetch(:partial) ? "Partial" : "OK" %></span>
      <span class="metric-label">Current search state</span>
    </article>
  </section>

  <section class="panel">
    <div class="panel-heading">
      <div>
        <h2>Search</h2>
        <p>Use this to exercise live NPS search, stored source fallback, and canonical dedupe.</p>
      </div>
    </div>

    <%= form_with url: root_path, method: :get, class: "search-form" do |form| %>
      <div class="field query-field">
        <%= form.label :q, "Query" %>
        <%= form.search_field :q, value: @query, placeholder: "pinnacles" %>
      </div>
      <div class="field">
        <%= form.label :sources, "Sources" %>
        <%= form.text_field :sources, value: @sources %>
      </div>
      <div class="field">
        <%= form.label :types, "Types" %>
        <%= form.text_field :types, value: @types %>
      </div>
      <div class="field small-field">
        <%= form.label :limit, "Limit" %>
        <%= form.number_field :limit, value: @limit, min: 1, max: 25 %>
      </div>
      <%= form.submit "Search", class: "button primary" %>
    <% end %>

    <div class="status-row" aria-label="Source statuses">
      <% @search_response.fetch(:source_statuses).each do |status| %>
        <span class="status-pill <%= status.fetch(:status) %>">
          <%= status.fetch(:source).humanize %>: <%= status.fetch(:status).humanize %>
        </span>
      <% end %>
    </div>
  </section>

  <section class="panel">
    <div class="panel-heading">
      <div>
        <h2>Search Results</h2>
        <p><%= pluralize(@search_response.fetch(:results).size, "result") %> returned from the API service object.</p>
      </div>
      <code><%= @api_url %></code>
    </div>

    <% if @search_response.fetch(:results).any? %>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Name</th>
              <th>Type</th>
              <th>Category</th>
              <th>Source</th>
              <th>Source ID</th>
              <th>Coordinate</th>
              <th>Freshness</th>
            </tr>
          </thead>
          <tbody>
            <% @search_response.fetch(:results).each do |result| %>
              <% coordinate = result[:coordinate] || result["coordinate"] || {} %>
              <% freshness = result[:source_freshness] || result["source_freshness"] || {} %>
              <% latitude = coordinate[:lat] || coordinate["lat"] %>
              <% longitude = coordinate[:lng] || coordinate["lng"] %>
              <tr>
                <td>
                  <strong><%= result[:name] || result["name"] %></strong>
                  <% if result[:canonical_place_id] || result["canonical_place_id"] %>
                    <span class="muted">Canonical #<%= result[:canonical_place_id] || result["canonical_place_id"] %></span>
                  <% end %>
                </td>
                <td><%= (result[:result_type] || result["result_type"]).to_s.humanize %></td>
                <td><%= result[:category] || result["category"] %></td>
                <td><%= result[:source] || result["source"] %></td>
                <td><%= result[:source_id] || result["source_id"] || "-" %></td>
                <td><%= latitude.present? && longitude.present? ? "#{latitude}, #{longitude}" : "-" %></td>
                <td><%= freshness[:mode] || freshness["mode"] %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <p class="empty-state">No results yet. Search for a real NPS term like <%= link_to "pinnacles", root_path(q: "pinnacles", sources: "nps") %>.</p>
    <% end %>
  </section>

  <section class="panel">
    <div class="panel-heading">
      <div>
        <h2>Stored Source Records</h2>
        <p>Latest records persisted from real provider responses observed by the API.</p>
      </div>
    </div>

    <% if @latest_source_records.any? %>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Name</th>
              <th>Provider</th>
              <th>Record Type</th>
              <th>Source ID</th>
              <th>Fetched</th>
              <th>Expires</th>
            </tr>
          </thead>
          <tbody>
            <% @latest_source_records.each do |record| %>
              <tr>
                <td><strong><%= record.name %></strong></td>
                <td><%= record.provider %></td>
                <td><%= record.record_type.humanize %></td>
                <td><code><%= record.source_id %></code></td>
                <td><%= record.fetched_at&.to_fs(:db) %></td>
                <td><%= record.expires_at&.to_fs(:db) || "-" %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <p class="empty-state">No source records stored yet. A successful live NPS search will persist what it saw.</p>
    <% end %>
  </section>
</main>
